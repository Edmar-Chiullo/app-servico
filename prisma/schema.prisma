generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           String   @default("ATTENDANT")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts           Account[]
  sessions           Session[]
  createdTechnicians   Technician[]        @relation("TechnicianCreator")
  statusHistories      StatusHistory[]
  stockMovements       StockMovement[]
  auditLogs            AuditLog[]
  financialExits       FinancialExit[]
  whatsappMessages     WhatsAppMessage[]
  serviceOrdersCreated ServiceOrder[]       @relation("ServiceOrderCreator")
  ownershipHistories   OwnershipHistory[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  cpf          String   @unique
  phone        String
  whatsapp     String?
  email        String?
  street       String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vehicles         Vehicle[]
  serviceOrders    ServiceOrder[]
  whatsappMessages WhatsAppMessage[]

  @@index([name, cpf])
  @@map("customers")
}

model Vehicle {
  id        String   @id @default(cuid())
  plate     String   @unique
  brand     String?
  model     String
  year      Int?
  color     String
  mileage   Int?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  serviceOrders     ServiceOrder[]
  ownershipHistories OwnershipHistory[]

  @@index([plate, model, color])
  @@map("vehicles")
}

model OwnershipHistory {
  id                 String   @id @default(cuid())
  vehicleId          String
  vehicle            Vehicle  @relation(fields: [vehicleId], references: [id])
  previousCustomerId String?
  newCustomerId      String
  changedByUserId    String
  changedBy          User     @relation(fields: [changedByUserId], references: [id])
  changedAt          DateTime @default(now())

  @@map("ownership_histories")
}

model Technician {
  id        String   @id @default(cuid())
  name      String
  cpf       String   @unique
  role      String
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUserId String
  createdBy       User     @relation("TechnicianCreator", fields: [createdByUserId], references: [id])

  serviceOrders ServiceOrder[]

  @@index([name, cpf])
  @@map("technicians")
}

model Product {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String
  category      String?
  unit          String   @default("UN")
  stockQuantity Int      @default(0)
  stockMin      Int      @default(0)
  stockMax      Int      @default(0)
  costPrice     Float    @default(0)
  salePrice     Float    @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stockMovements       StockMovement[]
  serviceOrderProducts ServiceOrderProduct[]

  @@index([code, description])
  @@map("products")
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String
  quantity  Int
  reason    String
  createdAt DateTime @default(now())

  userId  String?
  user    User?   @relation(fields: [userId], references: [id])
  orderId String?
  order   ServiceOrder? @relation(fields: [orderId], references: [id])

  @@map("stock_movements")
}

model ServiceOrder {
  id                 String   @id @default(cuid())
  number             Int      @unique
  problemDescription String
  priority           String   @default("normal")
  status             String   @default("OPEN")
  openingDate        DateTime @default(now())
  completionDate     DateTime?
  diagnostic         String?
  executedService    String?
  laborValue         Float    @default(0)
  materialsValue     Float    @default(0)
  totalValue         Float    @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customerId       String
  customer         Customer     @relation(fields: [customerId], references: [id])
  vehicleId        String
  vehicle          Vehicle      @relation(fields: [vehicleId], references: [id])
  technicianId     String
  technician       Technician   @relation(fields: [technicianId], references: [id])
  responsibleUserId String
  responsibleUser  User         @relation("ServiceOrderCreator", fields: [responsibleUserId], references: [id])

  statusHistories      StatusHistory[]
  serviceOrderProducts  ServiceOrderProduct[]
  stockMovements       StockMovement[]
  financialEntries     FinancialEntry[]

  @@index([number, status, openingDate])
  @@map("service_orders")
}

model ServiceOrderProduct {
  id         String @id @default(cuid())
  quantity   Int
  unitPrice  Float
  totalPrice Float

  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  productId      String
  product        Product      @relation(fields: [productId], references: [id])

  @@unique([serviceOrderId, productId])
  @@map("service_order_products")
}

model StatusHistory {
  id              String   @id @default(cuid())
  fromStatus      String?
  toStatus        String
  changedAt       DateTime @default(now())

  serviceOrderId  String
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  changedByUserId String
  changedBy       User         @relation(fields: [changedByUserId], references: [id])

  @@map("status_histories")
}

model FinancialEntry {
  id             String   @id @default(cuid())
  value          Float
  date           DateTime @default(now())
  createdAt      DateTime @default(now())

  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([date])
  @@map("financial_entries")
}

model FinancialExit {
  id          String   @id @default(cuid())
  description String
  value       Float
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@index([date])
  @@map("financial_exits")
}

model WhatsAppMessage {
  id         String   @id @default(cuid())
  phone      String
  message    String
  status     String
  sentAt     DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  sentByUserId String?
  sentBy       User?   @relation(fields: [sentByUserId], references: [id])

  @@map("whatsapp_messages")
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String?
  operation  String
  changes    String?
  createdAt  DateTime @default(now())

  userId String?
  user   User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId, createdAt])
  @@map("audit_logs")
}

model CompanySettings {
  id           String   @id @default("default")
  name         String
  logo         String?
  cnpj         String?
  phone        String?
  email        String?
  street       String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  updatedAt    DateTime @updatedAt

  @@map("company_settings")
}
